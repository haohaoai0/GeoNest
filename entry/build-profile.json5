{
  "apiType": "stageMode",
  "buildOption": {
    "resOptions": {
      "copyCodeResource": {
        "enable": true
      }
    },
    "externalNativeOptions": {
      "abiFilters": [
        "arm64-v8a",
        "x86_64"
      ],
      "path": "./src/main/cpp/CMakeLists.txt",
      "arguments": "-DGEONEST_USE_QGIS_CORE=ON -DQGIS_PREFIX=F:/HarmonyProjects/GeoNest/native/third_party/qgis/stage -DQT6_PREFIX=F:/HarmonyProjects/GeoNest/native/third_party/qt6/stage",
      "cppFlags": ""
    }
  },
  "buildOptionSet": [
    {
      "name": "release",
      "arkOptions": {
        "obfuscation": {
          "ruleOptions": {
            "enable": false,
            "files": [
              "./obfuscation-rules.txt"
            ]
          }
        }
      }
    },
  ],
  "targets": [
    {
      "name": "default"
    },
    {
      "name": "ohosTest",
    }
  ]
}
